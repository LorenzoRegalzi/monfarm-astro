---
// Contact form component
// Submissions handled via Netlify Forms or a custom endpoint
---

<form
  class="contact-form"
  name="contatti"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  novalidate
  id="contact-form"
>
  <!-- Honeypot anti-spam -->
  <p hidden>
    <label>Non compilare: <input name="bot-field" /></label>
  </p>

  <div class="contact-form__row">
    <div class="contact-form__field">
      <label class="contact-form__label" for="nome">Nome</label>
      <input
        class="contact-form__input"
        type="text"
        id="nome"
        name="nome"
        placeholder="Nome"
        autocomplete="given-name"
        required
        aria-required="true"
      />
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="cognome">Cognome</label>
      <input
        class="contact-form__input"
        type="text"
        id="cognome"
        name="cognome"
        placeholder="Cognome"
        autocomplete="family-name"
        required
        aria-required="true"
      />
    </div>
  </div>

  <div class="contact-form__field">
    <label class="contact-form__label" for="email">Mail</label>
    <input
      class="contact-form__input"
      type="email"
      id="email"
      name="email"
      placeholder="Mail"
      autocomplete="email"
      required
      aria-required="true"
    />
  </div>

  <div class="contact-form__field">
    <label class="contact-form__label" for="motivo">Cosa ti porta qui?</label>
    <div class="contact-form__select-wrap">
      <select
        class="contact-form__select"
        id="motivo"
        name="motivo"
        required
        aria-required="true"
      >
        <option value="" disabled selected>Cosa ti porta qui?</option>
        <option value="struttura-location">Struttura/location</option>
        <option value="operatore-insegnante">Operatore/insegnante</option>
        <option value="partecipare">Vorrei partecipare</option>
        <option value="altro">Altro</option>
      </select>
      <span class="contact-form__select-arrow" aria-hidden="true">
        <svg width="14" height="9" viewBox="0 0 14 9" fill="none">
          <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>

  <div class="contact-form__field">
    <label class="contact-form__label" for="messaggio">Messaggio</label>
    <textarea
      class="contact-form__textarea"
      id="messaggio"
      name="messaggio"
      placeholder="Messaggio"
      rows="7"
      required
      aria-required="true"
    ></textarea>
  </div>

  <div class="contact-form__privacy">
    <label class="contact-form__checkbox-label">
      <input
        class="contact-form__checkbox"
        type="checkbox"
        name="privacy"
        required
        aria-required="true"
        aria-describedby="privacy-desc"
      />
      <span id="privacy-desc">
        Accetto la
        <a href="/privacy-policy" target="_blank" rel="noopener noreferrer">
          privacy policy
        </a>
      </span>
    </label>
  </div>

  <div class="contact-form__submit">
    <button type="submit" class="btn btn--primary contact-form__btn">
      Invia messaggio
    </button>
  </div>

  <!-- Success / error messages (shown via JS) -->
  <p class="contact-form__success" role="alert" hidden>
    Grazie! Ti risponderemo al più presto.
  </p>
  <p class="contact-form__error" role="alert" hidden>
    Si è verificato un errore. Riprova o scrivici direttamente su Instagram.
  </p>
</form>

<style>
.contact-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  max-width: 520px;
  margin-inline: auto;
}

.contact-form__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
}

@media (max-width: 480px) {
  .contact-form__row {
    grid-template-columns: 1fr;
  }
}

.contact-form__field {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.contact-form__label {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-light);
}

/* Shared input styles */
.contact-form__input,
.contact-form__select,
.contact-form__textarea {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-brown);
  border-radius: 0;
  padding: 0.55rem 0;
  font-family: var(--font-sans);
  font-size: 1rem;
  color: var(--color-brown);
  outline: none;
  transition: border-color var(--transition);
  appearance: none;
  -webkit-appearance: none;
}

.contact-form__input::placeholder,
.contact-form__textarea::placeholder {
  color: var(--color-text-light);
}

.contact-form__input:focus,
.contact-form__select:focus,
.contact-form__textarea:focus {
  border-bottom-color: var(--color-olive);
}

/* Textarea */
.contact-form__textarea {
  resize: vertical;
  min-height: 140px;
  border: 1px solid var(--color-brown);
  border-radius: var(--border-radius);
  padding: 0.75rem;
  margin-top: 0.25rem;
}

/* Select wrapper */
.contact-form__select-wrap {
  position: relative;
}

.contact-form__select {
  cursor: pointer;
  padding-right: 2rem;
}
.contact-form__select option[value=""][disabled] {
  color: var(--color-text-light);
}

.contact-form__select-arrow {
  position: absolute;
  right: 0.25rem;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: var(--color-brown);
}

/* Privacy checkbox */
.contact-form__privacy {
  margin-top: var(--space-xs);
}

.contact-form__checkbox-label {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  font-size: 0.9rem;
  color: var(--color-text);
  cursor: pointer;
  line-height: 1.5;
}

.contact-form__checkbox {
  flex-shrink: 0;
  width: 16px;
  height: 16px;
  margin-top: 2px;
  border: 1px solid var(--color-brown);
  border-radius: 2px;
  cursor: pointer;
  accent-color: var(--color-olive);
}

.contact-form__checkbox-label a {
  color: var(--color-olive);
  text-decoration: underline;
}

/* Submit */
.contact-form__submit {
  display: flex;
  justify-content: center;
}

.contact-form__btn {
  min-width: 200px;
}

/* Feedback messages */
.contact-form__success {
  text-align: center;
  color: var(--color-olive);
  font-weight: 600;
}
.contact-form__error {
  text-align: center;
  color: var(--color-terracotta);
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const successMsg = form.querySelector('.contact-form__success') as HTMLElement;
      const errorMsg   = form.querySelector('.contact-form__error') as HTMLElement;
      const btn        = form.querySelector('.contact-form__btn') as HTMLButtonElement;

      btn.disabled = true;
      btn.textContent = 'Invio in corso…';

      try {
        const data = new FormData(form);
        const res  = await fetch(form.action || '/', {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' },
        });
        if (res.ok) {
          form.reset();
          successMsg.hidden = false;
          errorMsg.hidden = true;
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorMsg.hidden = false;
        successMsg.hidden = true;
        btn.disabled = false;
        btn.textContent = 'Invia messaggio';
      }
    });
  }
</script>
