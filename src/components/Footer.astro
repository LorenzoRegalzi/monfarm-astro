---
const year = new Date().getFullYear();
---

<footer class="site-footer">

  <!-- Main footer body -->
  <div class="footer-body">
    <div class="container footer-body__inner">

      <!-- Logo centrato -->
      <a href="/" class="footer-logo">
        <img src="/images/logo.svg" alt="MonFarm Experience" width="160" height="70" loading="lazy" />
      </a>

      <!-- Tagline + nav a due colonne -->
      <div class="footer-mid">
        <p class="footer-tagline">
          Un format di esperienze immersive nella natura, nato per creare
          <strong>connessioni autentiche</strong>.
        </p>

        <nav class="footer-nav" aria-label="Navigazione footer">
          <ul role="list">
            <li><a href="/">HOME</a></li>
            <li><a href="/il-format">IL FORMAT</a></li>
            <li><a href="/a-chi-e-rivolto">A CHI E' RIVOLTO</a></li>
            <li><a href="/esperienze">ESPERIENZE</a></li>
            <li><a href="/collabora">COLLABORA</a></li>
          </ul>
        </nav>
      </div>

      <!-- Contatti -->
      <ul class="footer-contacts" role="list">
        <li class="footer-contacts__item">
          <!-- Globe icon -->
          <svg class="footer-contacts__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <span>WWW.MONFARMEXPERIENCE.IT</span>
        </li>
        <li class="footer-contacts__item">
          <!-- Phone icon -->
          <svg class="footer-contacts__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="2"/>
            <circle cx="12" cy="17" r="1"/>
          </svg>
          <span>+39 3209318074</span>
        </li>
        <li class="footer-contacts__item">
          <!-- Location pin icon -->
          <svg class="footer-contacts__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span>CASALE MONFERRATO<br/>15033 (AL)</span>
        </li>
      </ul>

    </div>
  </div>

  <!-- Community band -->
  <div class="footer-community">
    <div class="container footer-community__inner">
      <h2 class="footer-community__title">Entra nella community<br />MonFarm Experience!</h2>
      <div class="footer-social">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/monfarmexperience"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social__icon"
          aria-label="MonFarm Experience su Instagram"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/monfarmexperience"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social__icon"
          aria-label="MonFarm Experience su Facebook"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@monfarmexperience"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social__icon"
          aria-label="MonFarm Experience su TikTok"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.73a4.85 4.85 0 0 1-1.01-.04z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p>&copy; {year} MonFarm Experience</p>
      <p>
        <a href="/privacy-policy">Privacy Policy</a>
        &nbsp;·&nbsp;
        <a href="/privacy-policy">Cookie Policy</a>
      </p>
    </div>
  </div>

</footer>

<style>
/* ---- Main body ---- */
.footer-body {
  background-color: var(--color-cream-bg);
  padding-block: var(--space-xl);
  border-top: 1px solid var(--color-cream);
}

.footer-body__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
  text-align: center;
}

.footer-logo img {
  height: 56px;
  width: auto;
}

.footer-mid {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
  width: 100%;
}

@media (min-width: 600px) {
  .footer-mid {
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
    text-align: left;
    gap: var(--space-xl);
  }
}

.footer-tagline {
  font-family: var(--font-sans);
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--color-text);
  max-width: 260px;
}

.footer-tagline strong {
  font-weight: 700;
  color: var(--color-brown);
}

.footer-nav ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  text-align: right;
}

.footer-nav a {
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-text-light);
  text-decoration: none;
  transition: color var(--transition);
  line-height: 2;
}
.footer-nav a:hover { color: var(--color-brown); }

/* Contacts */
.footer-contacts {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  align-items: flex-start;
  width: 100%;
}

.footer-contacts__item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-family: var(--font-sans);
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--color-text-light);
  line-height: 1.5;
}

.footer-contacts__icon {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  margin-top: 0.1rem;
  color: var(--color-text-light);
}

/* ---- Community band ---- */
.footer-community {
  background-color: var(--color-cream);
  padding-block: var(--space-xl);
}

.footer-community__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
  text-align: center;
}

.footer-community__title {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(1.4rem, 4vw, 2rem);
  color: var(--color-brown);
  line-height: 1.3;
}

.footer-social {
  display: flex;
  gap: var(--space-md);
  align-items: center;
}

.footer-social__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background-color: var(--color-brown);
  color: var(--color-cream-bg);
  text-decoration: none;
  transition: opacity var(--transition), transform var(--transition);
}
.footer-social__icon svg {
  width: 26px;
  height: 26px;
}
.footer-social__icon:hover {
  opacity: 0.8;
  transform: translateY(-2px);
}

/* ---- Bottom bar ---- */
.footer-bottom {
  background-color: var(--color-olive);
  padding-block: var(--space-md);
}

.footer-bottom__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  text-align: center;
}

.footer-bottom p {
  font-size: 0.8rem;
  color: var(--color-cream-bg);
  opacity: 0.9;
}

.footer-bottom a {
  color: var(--color-cream-bg);
  text-decoration: underline;
  opacity: 0.8;
  transition: opacity var(--transition);
}
.footer-bottom a:hover { opacity: 1; }
</style>
