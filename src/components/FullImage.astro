---
interface Props {
  src: string;
  alt: string;
  height?: string;
  round?: boolean;
  loading?: 'lazy' | 'eager';
}

const { src, alt, height = '50vh', round = false, loading = 'lazy' } = Astro.props;
---

<div class:list={['full-image', { 'full-image--round': round }]} style={!round ? `height: ${height};` : undefined}>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
  />
</div>

<style>
.full-image {
  width: 100%;
  overflow: hidden;
}

.full-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Variante circolare */
.full-image--round {
  width: 260px;
  height: 260px;
  border-radius: 50%;
  flex-shrink: 0;
  align-self: center;
}
</style>
