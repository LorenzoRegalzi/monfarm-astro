---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<section class="page-header">
  <div class="container page-header__inner">
    <div class="page-header__top">
      <!-- Lotus outline SVG -->

      <img
        src="/images/lotus.svg"
        alt="MonFarm Experience"
        class="page-header__logo"
        loading="eager"
      />
    </div>

    <h1 class="text-h1">{title}</h1>
  </div>
</section>

<style>
.page-header {
  background-color: var(--color-cream-bg);
  padding-block: var(--space-lg) var(--space-md);
}

.page-header__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  text-align: center;
}

.page-header__top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-md);
}

.page-header__lotus {
  width: 52px;
  height: 44px;
  color: var(--color-olive);
  flex-shrink: 0;
}

.page-header__logo {
  height: 42px;
  width: auto;
}

.page-header__title {
  font-family: var(--font-serif);
  font-size: clamp(1.8rem, 6vw, 2.8rem);
  font-weight: 700;
  color: var(--color-brown);
  line-height: 1.15;
  margin: 0;
}
</style>
