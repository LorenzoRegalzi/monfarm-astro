---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionCenter from '../components/SectionCenter.astro';
import SectionDivider from '../components/SectionDivider.astro';
import FullImage from '../components/FullImage.astro';
---

<Layout
  title="Contatti"
  description="Contatta MonFarm Experience: sei una struttura, un operatore o vuoi partecipare? Scrivici, ti risponderò personalmente."
>

  <PageHeader title="Contatti" />

  <SectionCenter>
    <h3>
      Se senti che MonFarm Experience potrebbe essere in sintonia con il tuo
      spazio, il tuo lavoro o il tuo percorso, scrivimi.
    <h3/>
        <h3>
       <em>Ogni collaborazione nasce da una conversazione.
        Raccontami chi sei, cosa fai e cosa ti piacerebbe costruire insieme.</em>
        <br />
        </h3>
          <h3>
      Ti risponderò personalmente.
    </h3>
  </SectionCenter>

  <!-- ===== BEATRICE PHOTO ===== -->
  <FullImage src="/images/contact_1.png" alt="Beatrice Furia sorridente in un prato durante un'esperienza MonFarm" />

  <!-- ===== FORM ===== -->
  <section class="section contatti-form-section">
    <div class="container">
      <ContactForm />
    </div>
  </section>

  <SectionDivider />

  <!-- ===== RELAZIONALE QUOTE ===== -->
  <SectionCenter>
      <h2>
        MonFarm Experience è un <em>progetto relazionale</em>:
        ogni incontro è il punto di partenza.
      </h2>
    </div>
  </SectionCenter>
  <FullImage src="/images/contact_2.png" alt="Beatrice Furia sorridente in un prato durante un'esperienza MonFarm" />

 


   <SectionCenter>
    <h3>
     Preferisci scrivere direttamente?
    <h3/>
    <h3>
      <a href="mailto:info@monfarmexperience.it">info@monfarmexperience.it</a>
    </h3>
  </SectionCenter>

</Layout>

<style>
/* ---- Intro ---- */
.contatti-intro {
  padding-bottom: 0;
  text-align: center;
}

.contatti-intro__text {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--color-text-light);
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: var(--space-md);
}

.contatti-intro__quote {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(1.1rem, 3.5vw, 1.4rem);
  line-height: 1.55;
  color: var(--color-brown);
  max-width: 460px;
  margin-inline: auto;
  margin-bottom: var(--space-sm);
}

.contatti-intro__personal {
  font-size: 1.1rem;
  color: var(--color-olive);
  font-weight: 400;
}

.contatti-intro__personal strong {
  font-weight: 700;
}

/* ---- Full image ---- */
.full-image {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
}

.full-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
}

/* ---- Form section ---- */
.contatti-form-section {
  padding-top: var(--space-xl);
}

/* ---- Email diretto ---- */
.email-section {
  background-color: var(--color-cream);
  padding-block: var(--space-xl);
}

.email-section__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  text-align: center;
}

.email-section__label {
  font-size: 1rem;
  color: var(--color-text-light);
}

.email-section__address {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(1rem, 3vw, 1.3rem);
  color: var(--color-brown);
  text-decoration: none;
  transition: opacity var(--transition);
}

.email-section__address:hover {
  opacity: 0.7;
}

/* ---- Relazionale quote ---- */
.relazionale-quote {
  padding-block: var(--space-xl);
  text-align: center;
}

.relazionale-quote__text {
  font-family: var(--font-serif);
  font-size: clamp(1.15rem, 4vw, 1.6rem);
  line-height: 1.5;
  color: var(--color-brown);
  max-width: 480px;
  margin-inline: auto;
}

.relazionale-quote__text em {
  font-style: italic;
}
</style>
