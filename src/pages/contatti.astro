---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionCenter from '../components/SectionCenter.astro';
import SectionDivider from '../components/SectionDivider.astro';
import FullImage from '../components/FullImage.astro';
---

<Layout
  title="Contatti"
  description="Contatta MonFarm Experience: sei una struttura, un operatore o vuoi partecipare? Scrivici, ti risponderò personalmente."
>

  <PageHeader title="Contatti" />

  <SectionCenter>
    <h3>
      Se senti che MonFarm Experience potrebbe essere in sintonia con il tuo
      spazio, il tuo lavoro o il tuo percorso, scrivimi.
    <h3/>
        <h3>
       <em>Ogni collaborazione nasce da una conversazione.
        Raccontami chi sei, cosa fai e cosa ti piacerebbe costruire insieme.</em>
        <br />
        </h3>
          <h3>
      Ti risponderò personalmente.
    </h3>
  </SectionCenter>

  <!-- ===== BEATRICE PHOTO ===== -->
  <FullImage src="/images/contatti/contatti-1.webp" alt="Beatrice Furia sorridente in un prato durante un'esperienza MonFarm" />

  <!-- ===== FORM ===== -->
  <section class="section contatti-form-section">
    <div class="container">
      <ContactForm />
    </div>
  </section>

  <SectionDivider />

  <!-- ===== RELAZIONALE QUOTE ===== -->
  <SectionCenter>
      <h2>
        MonFarm Experience è un <em>progetto relazionale</em>:
        ogni incontro è il punto di partenza.
      </h2>
    </div>
  </SectionCenter>
  <FullImage src="/images/contatti/contatti-2.webp" alt="Beatrice Furia sorridente in un prato durante un'esperienza MonFarm" />

 


   <SectionCenter>
    <h3>
     Preferisci scrivere direttamente?
    <h3/>
    <h3>
      <a href="mailto:info@monfarmexperience.it">info@monfarmexperience.it</a>
    </h3>
  </SectionCenter>

</Layout>

<style>
.contatti-form-section {
  padding-top: var(--space-xl);
}
</style>
