---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Contatti"
  description="Contatta MonFarm Experience: sei una struttura, un operatore o vuoi partecipare? Scrivici, ti risponderò personalmente."
>

  <PageHeader title="Contatti" />

  <!-- ===== INTRO ===== -->
  <section class="section contatti-intro">
    <div class="container">
      <p class="contatti-intro__text">
        Se senti che MonFarm Experience potrebbe essere in sintonia con il tuo
        spazio, il tuo lavoro o il tuo percorso, scrivimi.
      </p>
      <p class="contatti-intro__quote">
        <em>Ogni collaborazione nasce da una conversazione.</em><br />
        Raccontami chi sei, cosa fai e cosa ti piacerebbe costruire insieme.
      </p>
      <p class="contatti-intro__personal">
        Ti risponderò <strong>personalmente</strong>.
      </p>
    </div>
  </section>

  <!-- ===== BEATRICE PHOTO ===== -->
  <div class="full-image">
    <img
      src="/images/beatrice-campo.jpg"
      alt="Beatrice Furia sorridente in un prato durante un'esperienza MonFarm"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- ===== FORM ===== -->
  <section class="section contatti-form-section">
    <div class="container">
      <ContactForm />
    </div>
  </section>

  <!-- ===== EMAIL DIRETTO ===== -->
  <section class="section email-section">
    <div class="container email-section__inner">
      <p class="email-section__label">Preferisci scrivere direttamente?</p>
      <a
        href="mailto:info@monfarmexperience.it"
        class="email-section__address"
      >
        info@monfarmexperience.it
      </a>
    </div>
  </section>

  <!-- ===== RELAZIONALE QUOTE ===== -->
  <section class="relazionale-quote">
    <div class="container">
      <p class="relazionale-quote__text">
        MonFarm Experience è un <em>progetto relazionale</em>:
        ogni incontro è il punto di partenza.
      </p>
    </div>
  </section>

</Layout>

<style>
/* ---- Intro ---- */
.contatti-intro {
  padding-bottom: 0;
  text-align: center;
}

.contatti-intro__text {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--color-text-light);
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: var(--space-md);
}

.contatti-intro__quote {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(1.1rem, 3.5vw, 1.4rem);
  line-height: 1.55;
  color: var(--color-brown);
  max-width: 460px;
  margin-inline: auto;
  margin-bottom: var(--space-sm);
}

.contatti-intro__personal {
  font-size: 1.1rem;
  color: var(--color-olive);
  font-weight: 400;
}

.contatti-intro__personal strong {
  font-weight: 700;
}

/* ---- Full image ---- */
.full-image {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
}

.full-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
}

/* ---- Form section ---- */
.contatti-form-section {
  padding-top: var(--space-xl);
}

/* ---- Email diretto ---- */
.email-section {
  background-color: var(--color-cream);
  padding-block: var(--space-xl);
}

.email-section__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  text-align: center;
}

.email-section__label {
  font-size: 1rem;
  color: var(--color-text-light);
}

.email-section__address {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(1rem, 3vw, 1.3rem);
  color: var(--color-brown);
  text-decoration: none;
  transition: opacity var(--transition);
}

.email-section__address:hover {
  opacity: 0.7;
}

/* ---- Relazionale quote ---- */
.relazionale-quote {
  padding-block: var(--space-xl);
  text-align: center;
}

.relazionale-quote__text {
  font-family: var(--font-serif);
  font-size: clamp(1.15rem, 4vw, 1.6rem);
  line-height: 1.5;
  color: var(--color-brown);
  max-width: 480px;
  margin-inline: auto;
}

.relazionale-quote__text em {
  font-style: italic;
}
</style>
