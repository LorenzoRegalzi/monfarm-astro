---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import FullImage from '../components/FullImage.astro';
import SectionDividerNoBar from '../components/SectionDividerNoBar.astro';

const esperienze = [
  {
    date: 'OTTOBRE 2025',
    title: '"Evento Pilota: Le Radici"',
    location: 'Tenuta San Rocco',
    city: 'Conzano Monferrato (AL)',
    description:
      'Il nostro primo incontro, dove la visione ha preso forma. Due giorni immersi nei caldi colori autunnali per gettare i semi della community MonFarm, tra lentezza e prime pratiche condivise.',
    image: '/images/exp_1.png',
    imageAlt: "Gruppo di persone in cerchio al tramonto durante l'Evento Pilota Le Radici",
    instagramUrl: 'https://www.instagram.com/monfarmexperience',
  },
  {
    date: 'DICEMBRE 2025',
    title: '"Rituale d\'Inverno: la Luce che rinasce."',
    location: 'Belvedere Monferrato',
    city: 'Vignale Monferrato (AL)',
    description:
      'Un tempo per fermarsi e accogliere il silenzio della stagione fredda. Abbiamo condiviso pratiche introspettive e calore attorno al fuoco, per ritrovare la centratura prima del nuovo anno.',
    image: '/images/exp_2.png',
    imageAlt: 'Candela e oggetti sul pavimento durante il Rituale d\'Inverno a Belvedere Monferrato',
    instagramUrl: 'https://www.instagram.com/monfarmexperience',
    isPast: true,
  },
  {
    date: 'APRILE 2026',
    title: '"Risveglio e Fioritura"',
    location: 'La Corte Delle 4 Stagioni',
    city: 'Ozzano Monferrato (AL)',
    description:
      "Un'esperienza immersiva nella natura pensata per rallentare, ascoltarsi e lasciare emergere nuove energie. Tra pratiche dolci, condivisione e presenza, \"Risveglio e Fioritura\" è uno spazio protetto in cui concedersi tempo e trasformazione.",
    image: '/images/exp_3.png',
    imageAlt: "La Corte Delle 4 Stagioni — Ozzano Monferrato, sede dell'esperienza Risveglio e Fioritura",
    instagramUrl: 'https://www.instagram.com/monfarmexperience',
    isPast: false,
  },
];
---

<Layout
  title="Esperienze"
  description="Le esperienze MonFarm: ritiri immersi nella natura del Monferrato. Le Radici, Rituale d'Inverno, Risveglio e Fioritura."
>

  <PageHeader title="Esperienze" />

  {esperienze.map((exp, i) => (
    <>
      <FullImage src={exp.image} alt={exp.imageAlt} height="30vh" />
      <Section>
        <h2>{exp.date}</h2>
        <h2>{exp.title}</h2>
        <p>
          {exp.location}<br />
          {exp.city}
        </p>
        <p>{exp.description}</p>
        <Button href={exp.instagramUrl} text="Scopri com'è andata" />
      </Section>
      {i < esperienze.length - 1 && <SectionDividerNoBar />}
    </>
  ))}
 

</Layout>

<style>
/* ---- List ---- */
.esperienze-list {
  padding-top: var(--space-lg);
}

.exp-card {
  margin-bottom: var(--space-2xl);
}

/* ---- Image ---- */
.exp-card__image-wrap {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
  margin-bottom: var(--space-lg);
}

.exp-card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.exp-card:hover .exp-card__image-wrap img {
  transform: scale(1.02);
}

/* ---- Body ---- */
.exp-card__body {
  background-color: var(--color-cream);
  padding: var(--space-lg);
  border-radius: 4px;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.exp-card__accent-bar {
  width: 48px;
  height: 3px;
  background-color: var(--color-olive);
  margin-bottom: var(--space-xs);
}

.exp-card__date {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 1rem;
  color: var(--color-brown);
}

.exp-card__title {
  font-family: var(--font-serif);
  font-size: clamp(1.3rem, 5vw, 1.9rem);
  font-weight: 700;
  color: var(--color-brown);
  line-height: 1.25;
  margin-bottom: 0.2rem;
}

.exp-card__venue {
  font-size: 0.95rem;
  color: var(--color-text-light);
  line-height: 1.4;
}

.exp-card__city {
  font-size: 0.95rem;
  color: var(--color-text-light);
  line-height: 1.4;
}

.exp-card__desc {
  font-size: 0.97rem;
  line-height: 1.8;
  color: var(--color-text-light);
  margin-top: var(--space-sm);
}

.exp-card__cta-wrap {
  margin-top: var(--space-md);
  display: flex;
  justify-content: center;
}

/* ---- Diary / Instagram CTA ---- */
.diary-section {
  background-color: var(--color-cream);
  padding-block: var(--space-xl);
}

.diary-section__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
  text-align: center;
}

.diary-section__text {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(1.1rem, 3vw, 1.4rem);
  color: var(--color-brown);
  max-width: 400px;
}

.diary-section__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
</style>
