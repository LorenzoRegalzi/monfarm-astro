---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionDivider from '../components/SectionDivider.astro';
import HeroText from '../components/HeroText.astro';
import SectionCenter from '../components/SectionCenter.astro';
import Section from '../components/Section.astro';

const buildSteps = [
  {
    title: 'Il concept',
    text: "Ogni esperienza parte da un'intenzione chiara e da un tema guida.",
    icon: `<path d="M9 21h6M12 3a6 6 0 0 1 6 6c0 2.5-1.5 4.5-3 6H9c-1.5-1.5-3-3.5-3-6a6 6 0 0 1 6-6z"/><path d="M9 17h6"/>`,
  },
  {
    title: 'Il luogo',
    text: 'La scelta dello spazio non è casuale: deve essere coerente con la visione e favorire immersione e qualità relazionale.',
    icon: `<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>`,
  },
  {
    title: 'Gli operatori',
    text: 'Professionisti selezionati per affinità valoriale e capacità di lavorare in piccoli gruppi.',
    icon: `<circle cx="12" cy="8" r="4"/><path d="M12 14c-5 0-8 2.5-8 5v1h16v-1c0-2.5-3-5-8-5z"/>`,
  },
  {
    title: 'Il gruppo',
    text: 'Attenzione alla composizione dei partecipanti, per garantire armonia e profondità.',
    icon: `<circle cx="9" cy="8" r="3"/><circle cx="15" cy="8" r="3"/><path d="M3 20v-1c0-2 2.5-4 6-4"/><path d="M21 20v-1c0-2-2.5-4-6-4"/>`,
  },
  {
    title: 'La cura',
    text: 'Ogni dettaglio viene accompagnato con attenzione: ritmo, spazi, tempi e comunicazione.',
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
];
---

<Layout
  title="Il Format"
  description="Il format MonFarm Experience: un approccio lento, umano e curato. Come si costruisce un'esperienza."
>

  <PageHeader title="Il format" />
  <div class="approccio-image">
    <img
      src="/images/people-stretching.png"
      alt="Terrazza al tramonto con luci e sedie, atmosfera raccolta"
      loading="lazy"
      decoding="async"
    />
  </div>
  <SectionCenter>
    <h3>Un modo di progettare esperienze che mette al centro la
    relazione tra luogo, persone e pratiche.</h3>
  </SectionCenter>
  <SectionDivider />

  <Section>
    <h4>Rallentare per tornare all'essenziale</h4>
    <p>
              MonFarm nasce dal desiserio di creare spazi in cui il tempo possa dilatarsi e la presenza tornare al centro

    </p>
     <p>
        Crediamo nella natura come contesto generativo nella lentezza come valore e nell'incontro come esperienza trasformativa. Ogni proposta nasce da una visione chiara: favorire connessioni autentiche, lontane dalla logica della performance o del consumo. Non si trata di organizzare evneti ma di curare processi.

    </p>
  </Section>



  <div class="approccio-image">
    <img
      src="/images/hug.png"
      alt="Terrazza al tramonto con luci e sedie, atmosfera raccolta"
      loading="lazy"
      decoding="async"
    />
  </div>

  <SectionDivider />

  <!-- ===== COME SI COSTRUISCE ===== -->
  <Section>
      
      <h2>Come si costruisce<em> un'esperienza</em></h2>
     

      <ul class="build-list" role="list">
        {buildSteps.map((step) => (
          <li class="build-item">
            <div class="build-item__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={step.icon} />
            </div>
            <div>
              <h4>{step.title}</h4>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <SectionDivider />



  <Section>
          <h2 style="text-align: center; position: relative;
  top: 22px;">Mi presento</h2>

      <div class="mi-presento__card">
        <div class="mi-presento__image-wrap" >
          <img
            src="/images/beatrice.png"
            alt="Beatrice Furia, fondatrice e curatrice di MonFarm Experience"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="mi-presento__info">
          <h3>Beatrice Furia</h3>
          <p>Fondatrice e curatrice di MonFarm Experience.</p>
        </div>
      </div>
    </div>
    <h4>Il mio <em>ruolo</em></h4>
    <p>
          Il mio compito è tenere insieme tutti gli elementi dell'esperienza.
          Curo il concept, accompagno la progettazione con le strutture,
          seleziono gli operatori e custodisco la coerenza dell'intero percorso.
        </p>
        <p>
          Mi occupo della visione complessiva, affinché ogni esperienza sia
          armonica, autentica e rispettosa dei <strong>ritmi naturali</strong>.
        </p>
  </Section>

  <SectionDivider />
  <!-- ===== CLOSING QUOTE ===== -->
 <SectionCenter>
    <h3>
        <em>MonFarm Experience è un invito a progettare insieme spazi di qualità,
        in cui la relazione diventa il cuore dell'esperienza.</em>
        </h3>
  </SectionCenter>

</Layout>

<style>
/* ---- Intro ---- */
.format-intro {
  padding-bottom: 0;
}

.format-intro__para {
  font-size: 1rem;
  line-height: 1.85;
  color: var(--color-text-light);
  margin-bottom: var(--space-sm);
}

.format-intro__para strong {
  color: var(--color-brown);
  font-weight: 700;
}

/* ---- Approccio band ---- */
.approccio-band {
  background-color: var(--color-cream);
  padding-block: var(--space-xl);
}

.approccio-band__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-lg);
}

.approccio-band__title {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(1.6rem, 6vw, 2.5rem);
  color: var(--color-brown);
  line-height: 1.2;
}

.approccio-band__lotus {
  width: 110px;
  height: auto;
  color: rgba(255,255,255,0.5);
  flex-shrink: 0;
}

/* ---- Full-width image ---- */
.full-image {
  width: 100%;
  aspect-ratio: 16/9;
  overflow: hidden;
}

.full-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ---- Come si costruisce ---- */
.build-section__header {
  margin-bottom: var(--space-xl);
}

.build-section__title {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 5vw, 2.2rem);
  font-weight: 700;
  color: var(--color-brown);
  line-height: 1.3;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem 1rem;
}

.build-section__title em {
  font-style: italic;
  font-weight: 400;
}

.build-section__logo-inline {
  height: 32px;
  width: auto;
  display: inline-block;
  vertical-align: middle;
}

.build-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.build-item {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
}

.build-item__icon {
  flex-shrink: 0;
  width: 42px;
  height: 42px;
  color: var(--color-text-light);
}

.build-item__icon svg {
  width: 100%;
  height: 100%;
}

.build-item__title {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--color-brown);
  margin-bottom: 0.3rem;
}

.build-item p {
  font-size: 0.95rem;
  line-height: 1.75;
  color: var(--color-text-light);
}

/* ---- Mi presento ---- */
.mi-presento {

}

.mi-presento__inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.mi-presento__accent-bar {
  width: 48px;
  height: 3px;
  background-color: var(--color-olive);
}

.mi-presento__heading {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 7vw, 3rem);
  font-weight: 700;
  color: var(--color-brown);
  line-height: 1.1;
}

.mi-presento__heading em {
  font-style: italic;
  font-weight: 400;
}

.mi-presento__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
  text-align: center;
}

.mi-presento__image-wrap {
  width: 240px;
  height: 280px;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
}

.mi-presento__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
}

.mi-presento__name {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 4vw, 2rem);
  font-weight: 700;
  color: var(--color-brown);
}

.mi-presento__role {
  color: var(--color-text-light);
  font-size: 0.95rem;
  margin-top: 0.25rem;
}

/* ---- Il mio ruolo ---- */
.mio-ruolo__inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.mio-ruolo__accent-bar {
  width: 48px;
  height: 3px;
  background-color: var(--color-olive);
  margin-bottom: var(--space-xs);
}

.mio-ruolo__title {
  font-family: var(--font-serif);
  font-size: clamp(1.3rem, 4vw, 1.8rem);
  font-weight: 700;
  color: var(--color-brown);
  margin-bottom: var(--space-sm);
}

.mio-ruolo__title em {
  font-style: italic;
  font-weight: 400;
}

.mio-ruolo__inner p {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--color-text-light);
}

.mio-ruolo__inner strong {
  color: var(--color-olive);
  font-weight: 700;
}

/* ---- Closing quote ---- */
.closing-quote {
  padding-block: var(--space-xl);
}

.closing-quote__text {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(1.2rem, 4vw, 1.7rem);
  color: var(--color-brown);
  text-align: center;
  line-height: 1.55;
  max-width: 520px;
  margin-inline: auto;
  border: none;
  padding: 0;
}

/* ---- CTA ---- */
.format-cta-section {
  padding-block: var(--space-lg);
}

.format-cta-inner {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  justify-content: center;
}

.approccio-image {
  width: 100%;
  height: 50vh;
  aspect-ratio: 16/9;
  overflow: hidden;
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
}

.hero-text__title {
  font-family: var(--font-serif);
  font-size: clamp(1.45rem, 5vw, 2.2rem);
  font-weight: 400;
  line-height: 1.45;
  color: var(--color-brown);
  max-width: 560px;
  margin-inline: auto;
}

/* ---- Audience intro ---- */
.audience-intro {
  padding-block: var(--space-xl);
}

.audience-intro__title {
  font-family: var(--font-serif);
  font-size: clamp(1.3rem, 4vw, 1.8rem);
  font-weight: 700;
  color: var(--color-brown);
  margin-bottom: var(--space-sm);
  text-align: left;
}

.audience-intro__text {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--color-brown);
  text-align: left;
  max-width: 560px;
}

</style>
